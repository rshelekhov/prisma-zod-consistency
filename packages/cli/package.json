    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mrleebo/prisma-ast": "^0.12.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",

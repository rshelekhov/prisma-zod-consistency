{
  "name": "prisma-zod-consistency",
  "version": "0.10.0",
  "description": "CLI for prisma-zod-consistency — deterministic static analysis for Prisma + Zod + TypeScript projects. Catches drift between schema.prisma, Zod schemas, and TypeScript code.",
  "license": "MIT",
  "author": "Roman Shelekhov",
  "repository": {
    "type": "git",
    "url": "https://github.com/rshelekhov/prisma-zod-consistency.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/rshelekhov/prisma-zod-consistency/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/rshelekhov/prisma-zod-consistency/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "prisma-zod-consistency": "./dist/index.js",
    "pz-check": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "lint": "biome check src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mrleebo/prisma-ast": "^0.12.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "diff": "^7.0.0",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.10",
    "ts-morph": "^24.0.0"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11.0.0",
    "mysql2": ">=3.0.0",
    "postgres": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/diff": "^7.0.0",
    "@types/node": "^20.16.0",
    "@types/sarif": "^2.1.7",
    "ajv": "^8.17.1",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.5.0",
    "mysql2": "^3.11.0",
    "postgres": "^3.4.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "prisma",
    "zod",
    "consistency",
    "lint",
    "static-analysis",
    "database",
    "schema"
  ]
}

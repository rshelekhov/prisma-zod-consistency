    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "prisma",
    "zod",
    "consistency",
    "lint",
    "static-analysis",
    "database",

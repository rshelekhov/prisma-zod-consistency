// Good fixture for R01: Zod matches Prisma exactly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String   @id @default(cuid())
  email String   @unique @db.VarChar(255)
  name  String   @db.VarChar(100)
  age   Int
  tags  String[]
}
